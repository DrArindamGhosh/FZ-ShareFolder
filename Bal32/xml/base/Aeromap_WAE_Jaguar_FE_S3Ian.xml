<!-- ************************************************************************************************  -->
<!-- YAW MEASUREMENT POSITIONS  -->
<!-- ************************************************************************************************  --> 
<!-- The measurement of yaw angle varies along the length of the car.  --> 
<!-- Values are in metres in car-space (CAD).  --> 
<!-- ************************************************************************************************  --> 
<yaw_measurement>
<position name="fdf" value="0.000000" />
<position name="rdf" value="2.800000" />
<position name="drag" value="1.400000" />
<position name="sf" value="1.400000" />
<position name="sfpos" value="1.400000" />
<position name="fwl" value="0.000000" />
<position name="rwl" value="2.800000" />
</yaw_measurement>
<!-- ************************************************************************************************  -->
<!-- BASE-MAP DIMENSIONS DEFINED  --> 
<!-- ************************************************************************************************  --> 
<!-- The "frh" dimension has 9 grid position(s).  --> 
<!-- The "rrh" dimension has 6 grid position(s).  --> 
<!-- The "yaw" dimension has 1 grid position(s).  --> 
<!-- The "steer" dimension has 1 grid position(s).  --> 
<!-- This means that the base map needs to specify a total of 54  data points   --> 
<!-- ************************************************************************************************  --> 
<dimension identifier="frh">
<grid value="0.000000" />
<grid value="5.000000" />
<grid value="10.000000" />
<grid value="15.000000" />
<grid value="20.000000" />
<grid value="25.000000" />
<grid value="30.000000" />
<grid value="35.000000" />
<grid value="40.000000" />
</dimension>
<dimension identifier="rrh">
<grid value="10.000000" />
<grid value="20.000000" />
<grid value="30.000000" />
<grid value="40.000000" />
<grid value="50.000000" />
<grid value="60.000000" />
</dimension>
<dimension identifier="yaw">
<grid value="0.000000" />
</dimension>
<dimension identifier="steer">
<grid value="0.000000" />
</dimension>
<!-- ************************************************************************************************  --> 
<!-- OFFSET DIMENSIONS DEFINED  --> 
<!-- ************************************************************************************************  --> 
<!-- Here we define the lower-resolution 4 dimensional grid that applies to offsets.  --> 
<!-- These dimensions are defined with the base-map, because every offset used with a base-map  --> 
<!-- must share a common grid definiton (otherwise they can't be stacked-up).  --> 
<!-- The "frh" dimension has 5 grid position(s).  --> 
<!-- The "rrh" dimension has 8 grid position(s).  --> 
<!-- The "yaw" dimension has 7 grid position(s).  --> 
<!-- The "steer" dimension has 3 grid position(s).  --> 
<!-- This means that offset needs to specify a total of 840  data points   --> 
<!-- ************************************************************************************************  --> 
<!-- When it comes to specifying the actual data values in the offsets, any  --> 
<!-- dimension that is entirely unused (i.e. the component is insensitive to  --> 
<!-- motion in that dimension) need not be populated. For any given component, any dimension that  --> 
<!-- is used AT ALL must be populated IN ITS ENTIRETY  --> 
<!-- ************************************************************************************************  -->
<offset_dimension identifier="frh">
<grid value="0.000000" />
<grid value="5.000000" />
<grid value="10.000000" />
<grid value="15.000000" />
<grid value="20.000000" />
<grid value="25.000000" />
<grid value="30.000000" />
<grid value="35.000000" />
<grid value="40.000000" />
</offset_dimension>
<offset_dimension identifier="rrh">
<grid value="10.000000" />
<grid value="20.000000" />
<grid value="30.000000" />
<grid value="40.000000" />
<grid value="50.000000" />
<grid value="60.000000" />
</offset_dimension>
<offset_dimension identifier="yaw">
<grid value="0.000000" />
</offset_dimension>
<offset_dimension identifier="steer">
<grid value="0.000000" />
</offset_dimension>
<dimension_range identifier="frh" min="0.000000" max="40.000000"/> 
<dimension_range identifier="rrh" min="10.000000" max="60.000000"/> 
<dimension_range identifier="yaw" min="0.000000" max="0.000000"/> 
<dimension_range identifier="steer" min="0.000000" max="0.000000"/> 
