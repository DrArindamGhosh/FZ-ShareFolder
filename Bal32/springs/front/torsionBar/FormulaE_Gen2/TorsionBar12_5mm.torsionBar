<?xml version="1.0" standalone="yes" ?>
<torsionBar>

	<model>
		<units angleUnits="rad" stiffnessUnits = "Nm/rad" />
		<datapoint angle="0" 	stiffness="500" />
		<datapoint angle="0.05" stiffness="550" />
		<datapoint angle="0.1" 	stiffness="595" />
		<datapoint angle="0.15" stiffness="615" />
		<datapoint angle="0.2" 	stiffness="635" />
		<datapoint angle="0.25" stiffness="655" />
		<datapoint angle="0.5" 	stiffness="755" />
	</model>

</torsionBar>