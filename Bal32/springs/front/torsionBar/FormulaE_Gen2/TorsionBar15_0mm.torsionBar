<?xml version="1.0" standalone="yes" ?>
<torsionBar>

	<model>
		<units angleUnits="rad" stiffnessUnits = "Nm/rad" />
		<datapoint angle="0" 	stiffness="800" />
		<datapoint angle="0.05" stiffness="950" />
		<datapoint angle="0.1" 	stiffness="1110" />
		<datapoint angle="0.15" stiffness="1170" />
		<datapoint angle="0.2" 	stiffness="1210" />
		<datapoint angle="0.25" stiffness="1250" />
		<datapoint angle="0.5" 	stiffness="1450" />
	</model>

</torsionBar>