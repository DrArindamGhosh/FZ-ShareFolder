<?xml version="1.0" standalone="yes" ?>
<torsionBar>

	<model>
		<units angleUnits="rad" stiffnessUnits = "Nm/rad" />
		<datapoint angle="0" 	stiffness="650" />
		<datapoint angle="0.05" stiffness="750" />
		<datapoint angle="0.1" 	stiffness="850" />
		<datapoint angle="0.15" stiffness="870" />
		<datapoint angle="0.2" 	stiffness="900" />
		<datapoint angle="0.25" stiffness="920" />
		<datapoint angle="0.5" 	stiffness="1020" />
	</model>

</torsionBar>